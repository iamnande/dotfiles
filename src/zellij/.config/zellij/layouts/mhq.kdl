layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    // tardis plan
    tab name="plan" cwd="/home/iamnande/tardis" {
        pane stacked=true {
            pane name="shell"
            pane name="plan"
        }
    }

    // tardis build
    tab name="build" cwd="/home/iamnande/tardis" {
        pane stacked=true {
            pane name="editor"
            pane name="shell"
        }
    }

    // tardis run
    tab name="run" cwd="/home/iamnande/tardis" {
        pane stacked=true {
            pane name="svc / worker"
        }
        pane name="runtime" split_direction="vertical" {
            pane name="svc / client"
            pane name="svc / server"
        }
    }

    // tardis vcs
    tab name="vcs" cwd="/home/iamnande/tardis" {
        pane stacked=true {
            pane name="shell"
            pane name="vcs" command="lazygit"
        }
    }
    
}
