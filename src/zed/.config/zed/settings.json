// configure what serves. ignore what doesn't.
//
// full reference: https://zed.dev/docs/configuring-zed
// to examine defaults without disturbing what is set, run
// `zed: open default settings` from the command palette (ctrl-shift-p)
{
  "buffer_font_family": "OpenDyslexicM Nerd Font",
  "ui_font_family": "OpenDyslexicM Nerd Font Mono",
  "agent_servers": {
    
  },
  "git_panel": {
    "dock": "left"
  },
  "debugger": {
    "dock": "left"
  },
  "terminal": {
    "font_family": "OpenDyslexicM Nerd Font Mono",
    "dock": "bottom"
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "project_panel": {
    "dock": "left"
  },
  "restore_on_startup": "launchpad",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "session": {
    "trust_all_worktrees": true
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Everforest Dark Hard (blur)",
  },
  "wrap_guides": [80],
  "auto_install_extensions": {
    "everforest": true
  },
}
