#!/usr/bin/env fish
# senzu <identifier> [close]
# Start a senzu session for a Linear ticket, or close one.
# Usage:
#   senzu ADMIN-376        — fetch ticket, inject context, launch claude
#   senzu ADMIN-376 close  — transition ticket to done in Linear

set identifier $argv[1]
set subcommand $argv[2]

if test -z "$identifier"
    echo "usage: senzu <identifier> [close]" >&2
    exit 1
end

if test -z "$LINEAR_TOKEN"
    echo "error: LINEAR_TOKEN is not set" >&2
    exit 1
end

function _linear_post
    curl -sf \
        -X POST \
        -H "Authorization: $LINEAR_TOKEN" \
        -H "Content-Type: application/json" \
        -d $argv[1] \
        https://api.linear.app/graphql
end

function cmd_start
    set tmpfile (mktemp /tmp/senzu-XXXXXX.txt)

    senzu-fetch $identifier > $tmpfile
    if test $status -ne 0
        rm -f $tmpfile
        exit 1
    end

    set context (cat $tmpfile | string collect)
    rm -f $tmpfile

    exec claude \
        --name $identifier \
        --append-system-prompt $context
end

function cmd_close
    # fetch issue UUID + team ID
    set fetch_payload (jq -cn \
        --arg identifier $identifier \
        '{
            query: "query($identifier: String!) {
                issue(id: $identifier) { id team { id } }
            }",
            variables: { identifier: $identifier }
        }')

    set issue (_linear_post $fetch_payload | jq -r '.data.issue // empty')

    if test -z "$issue"
        echo "error: issue $identifier not found" >&2
        exit 1
    end

    set issue_id (echo $issue | jq -r '.id')
    set team_id  (echo $issue | jq -r '.team.id')

    # find the completed state for this team
    set states_payload (jq -cn \
        --arg teamId $team_id \
        '{
            query: "query($teamId: String!) {
                workflowStates(filter: { team: { id: { eq: $teamId } }, type: { eq: \"completed\" } }) {
                    nodes { id name }
                }
            }",
            variables: { teamId: $teamId }
        }')

    set done_state_id (_linear_post $states_payload | jq -r '.data.workflowStates.nodes[0].id // empty')

    if test -z "$done_state_id"
        echo "error: could not find a completed state for this team" >&2
        exit 1
    end

    read -P "close $identifier in Linear? [y/n] " confirm
    if test "$confirm" != "y"
        echo "aborted"
        exit 0
    end

    set update_payload (jq -cn \
        --arg id $issue_id \
        --arg stateId $done_state_id \
        '{
            query: "mutation($id: String!, $stateId: String!) {
                issueUpdate(id: $id, input: { stateId: $stateId }) {
                    success
                }
            }",
            variables: { id: $id, stateId: $stateId }
        }')

    set result (_linear_post $update_payload | jq -r '.data.issueUpdate.success')

    if test "$result" = "true"
        echo "$identifier closed"
    else
        echo "error: update failed" >&2
        exit 1
    end
end

switch $subcommand
    case close
        cmd_close
    case ''
        cmd_start
    case '*'
        echo "usage: senzu <identifier> [close]" >&2
        exit 1
end
